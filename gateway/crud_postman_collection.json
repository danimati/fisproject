{
  "info": {
    "name": "CRUD API Collection",
    "description": "Postman collection for CRUD operations including Roles, Role-User assignments, and User-Permission assignments",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "crud-api-collection"
  },
  "item": [
    {
      "name": "Roles",
      "item": [
        {
          "name": "Get All Roles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/crud/roles?skip=0&limit=100",
              "host": ["{{base_url}}"],
              "path": ["crud", "roles"],
              "query": [
                {
                  "key": "skip",
                  "value": "0",
                  "description": "Number of records to skip for pagination"
                },
                {
                  "key": "limit",
                  "value": "100",
                  "description": "Maximum number of records to return (1-1000)"
                }
              ]
            },
            "description": "Retrieve a list of all roles with pagination support"
          }
        },
        {
          "name": "Get Role by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/crud/roles/{{rol_id}}",
              "host": ["{{base_url}}"],
              "path": ["crud", "roles", "{{rol_id}}"]
            },
            "description": "Retrieve a specific role by its UUID"
          }
        },
        {
          "name": "Create Role",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Admin\",\n  \"descripcion\": \"Administrator role with full access\",\n  \"activo\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/crud/roles",
              "host": ["{{base_url}}"],
              "path": ["crud", "roles"]
            },
            "description": "Create a new role (Admin privileges required)"
          }
        },
        {
          "name": "Update Role",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Updated Role Name\",\n  \"descripcion\": \"Updated role description\",\n  \"activo\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/crud/roles/{{rol_id}}",
              "host": ["{{base_url}}"],
              "path": ["crud", "roles", "{{rol_id}}"]
            },
            "description": "Update an existing role by its UUID (Admin privileges required)"
          }
        },
        {
          "name": "Delete Role",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/crud/roles/{{rol_id}}",
              "host": ["{{base_url}}"],
              "path": ["crud", "roles", "{{rol_id}}"]
            },
            "description": "Deactivate a role by its UUID (Admin privileges required)"
          }
        }
      ],
      "description": "Role management endpoints"
    },
