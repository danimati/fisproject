# Gateway Configuration
APP_NAME="Maritime Gateway API"
APP_VERSION="1.0.0"
DEBUG=true
ENVIRONMENT=development

# Gateway Database (PostgreSQL)
DATABASE_URL=postgresql://felatiko:felatiko@localhost:5433/felatiko
DB_HOST=localhost
DB_PORT=5433
DB_name=felatiko
DB_USER=felatiko
DB_PASS=felatiko

# Backend API
BACKEND_URL=http://localhost:8000

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=gateway-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000
DOS_THRESHOLD=500

# CORS
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# Logging
LOG_LEVEL=INFO

# Encryption (32 characters for Fernet)
ENCRYPTION_KEY=encryption-key-32-chars-long-please
